<Window
    x:Class="OmegaDev2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:OmegaDev2.Pages">

    <Grid Background="{ThemeResource OmegaDev2.BgBrush}">
        <NavigationView x:Name="Nav"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        SelectionChanged="Nav_SelectionChanged"
                        Background="{ThemeResource OmegaDev2.BgBrush}">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="home">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Regions" />
                <NavigationViewItem Content="Teleport Pad" Tag="teleportpad">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Map" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Background="{ThemeResource OmegaDev2.BgBrush}" />
        </NavigationView>
    </Grid>
</Window>
