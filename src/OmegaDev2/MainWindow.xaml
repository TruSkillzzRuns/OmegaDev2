<Window
    x:Class="OmegaDev2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:OmegaDev2.Pages">

    <Grid Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">
        <NavigationView x:Name="Nav"
                        PaneDisplayMode="Left"
                        OpenPaneLength="280"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        SelectionChanged="Nav_SelectionChanged"
                        Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
                        Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}">

            <!-- Branded pane header + server status pill -->
            <NavigationView.PaneHeader>
                <Border Padding="14,14,12,14"
                        BorderBrush="{ThemeResource OmegaDev2.PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border CornerRadius="6" Width="34" Height="34" VerticalAlignment="Center">
                                <Image Source="ms-appx:///Assets/OmegaDev2Emblem.png"
                                       Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Spacing="0" VerticalAlignment="Center">
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           CharacterSpacing="180"
                                           Foreground="{ThemeResource OmegaDev2.AccentBrush}"
                                           Text="OmegaDev2" />
                                <TextBlock FontSize="10"
                                           Opacity="0.55"
                                           CharacterSpacing="240"
                                           FontWeight="SemiBold"
                                           Text="1.52.0.1700" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse x:Name="ServerStatusDot"
                                     Width="7" Height="7"
                                     Fill="{ThemeResource OmegaDev2.DangerBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock x:Name="ServerStatusText"
                                       FontSize="10"
                                       Opacity="0.75"
                                       VerticalAlignment="Center"
                                       Text="server: disconnected" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="home">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemHeader Content="REGIONS" />
                <NavigationViewItem Content="Teleport Pad" Tag="teleportpad">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE909;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemHeader Content="PHANTOMS" />
                <NavigationViewItem Content="Phantom Heroes" Tag="phantoms">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE716;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Squad Builder" Tag="squadbuilder">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE902;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="DPS Meter" Tag="dpsmeter">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemHeader Content="COMBAT" />
                <NavigationViewItem Content="Enemy Phantoms" Tag="enemyphantoms">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEA0B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Wave Director" Tag="wavedirector">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemHeader Content="LOOT" />
                <NavigationViewItem Content="Gear Picker" Tag="gearpicker">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7B8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Stash Manager" Tag="stashmanager">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF012;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemHeader Content="SERVER" />
                <NavigationViewItem Content="Account Manager" Tag="accounts">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Command Console" Tag="console">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE756;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Log Viewer" Tag="logviewer">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7C3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Diagnostics" Tag="diagnostics">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9F9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Asset Setup" Tag="setup">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE115;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Small footer strip so the pane never looks empty at the bottom -->
            <NavigationView.PaneFooter>
                <Border Padding="14,10,12,14"
                        BorderBrush="{ThemeResource OmegaDev2.PanelBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <TextBlock FontSize="10"
                               Opacity="0.55"
                               CharacterSpacing="120"
                               Text="OmegaDev2  ·  v0.3" />
                </Border>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" Background="{ThemeResource OmegaDev2.PageBackgroundBrush}" />
        </NavigationView>
    </Grid>
</Window>
