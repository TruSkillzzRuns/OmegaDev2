<Page
    x:Class="OmegaDev2.Pages.LeaderboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Leaderboard"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="Persistent best-of history — top DPS parses saved from the DPS Meter, and terminal run times logged automatically the moment you teleport into one (Taskmaster, Fisk Tower, etc.) at any difficulty."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="960"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ComboBox x:Name="KindCombo" SelectedIndex="0" SelectionChanged="KindCombo_SelectionChanged" Width="160">
                    <ComboBoxItem Content="All" Tag="" />
                    <ComboBoxItem Content="DPS Parses" Tag="DpsParse" />
                    <ComboBoxItem Content="Terminal Runs" Tag="TerminalRun" />
                </ComboBox>
                <TextBox x:Name="HeroBox" Width="200" PlaceholderText="filter by hero name..." />
                <TextBox x:Name="PlayerBox"
                         Width="200"
                         PlaceholderText="player (* = first online)"
                         Text="*"
                         VerticalAlignment="Center" />
                <Button Content="Refresh" Click="Refresh_Click" />
                <Button Content="Clear All" Click="ClearAll_Click" ToolTipService.ToolTip="Delete every saved entry for this player" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- List -->
        <Border Grid.Row="2"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="1" Text="HERO" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="2" Text="VALUE" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" HorizontalAlignment="Right" Margin="0,0,16,0" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="3" Text="REGION / TIER" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" Margin="16,0,0,0" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="4" Text="WHEN" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" HorizontalAlignment="Right" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                </Grid>

                <ListView x:Name="EntryList" Grid.Row="1" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:LeaderboardRow">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Rank}" FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind KindBadge}" FontSize="10" FontWeight="SemiBold" Opacity="0.55" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind HeroName}" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{x:Bind ValueText}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{x:Bind RegionText}" FontSize="12" Opacity="0.75" TextWrapping="Wrap" Margin="16,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="{x:Bind WhenText}" FontSize="11" Opacity="0.55" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <Button Grid.Column="5"
                                        Content="✕"
                                        FontSize="10"
                                        Padding="6,2"
                                        HorizontalAlignment="Right"
                                        Tag="{x:Bind Id}"
                                        Click="DeleteEntry_Click"
                                        ToolTipService.ToolTip="Delete this entry" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
