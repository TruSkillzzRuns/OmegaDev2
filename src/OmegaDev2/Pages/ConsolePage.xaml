<Page
    x:Class="OmegaDev2.Pages.ConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Command Console"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="Run any server command from here. Set a player to run client commands (!phantom, !region ...) as that player; leave * to use the first online player, or blank for server-console mode."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="960"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Output -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="4"
                    Margin="0,0,12,0">
                <ScrollViewer x:Name="OutputScroll" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="OutputText"
                               FontFamily="Consolas"
                               FontSize="12.5"
                               Padding="10"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                </ScrollViewer>
            </Border>

            <!-- History -->
            <Border Grid.Column="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Spacing="2" Margin="4,2,4,8">
                        <TextBlock Text="HISTORY"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="160"
                                   Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                        <TextBlock Text="click a command to reuse it"
                                   FontSize="10"
                                   Opacity="0.55"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    </StackPanel>
                    <ListView x:Name="HistoryList"
                              Grid.Row="1"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="HistoryList_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Grid.Row="2"
                            Content="Clear Output"
                            FontSize="11"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Stretch"
                            Click="ClearOutput_Click" />
                </Grid>
            </Border>
        </Grid>

        <!-- Input bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PlayerBox"
                         Grid.Column="0"
                         Header="Run as player"
                         Text="*"
                         Margin="0,0,10,0" />
                <TextBox x:Name="CommandBox"
                         Grid.Column="1"
                         Header="Command"
                         PlaceholderText="e.g. phantom spawn 5"
                         FontFamily="Consolas"
                         KeyDown="CommandBox_KeyDown"
                         Margin="0,0,10,0" />
                <Button x:Name="RunBtn"
                        Grid.Column="2"
                        Content="Run"
                        MinWidth="90"
                        VerticalAlignment="Bottom"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="Run_Click" />
            </Grid>
        </Border>
    </Grid>
</Page>
