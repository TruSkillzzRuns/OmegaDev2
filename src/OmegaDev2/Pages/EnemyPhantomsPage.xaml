<Page
    x:Class="OmegaDev2.Pages.EnemyPhantomsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Enemy Phantoms"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.DangerEmphasisBrush}" />
            <TextBlock Text="Spawn hostile AI heroes that hunt you and your squad — full power kits, real gear, killable. Your phantoms will fight back. Kills against you are never credited to anyone."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="920"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="LoadBtn" Content="Load Roster" Click="LoadRoster_Click" />
                <TextBox x:Name="SearchBox"
                         Width="220"
                         PlaceholderText="search hero..."
                         TextChanged="SearchBox_TextChanged"
                         VerticalAlignment="Center" />
                <TextBox x:Name="PlayerBox"
                         Width="220"
                         PlaceholderText="player (* = first online)"
                         Text="*"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Main: roster | hostiles | spawn -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Hero roster -->
            <Border Grid.Column="0"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="6"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Spacing="2" Margin="8,6,8,6">
                        <TextBlock Text="HERO ROSTER"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="180"
                                   Foreground="{ThemeResource OmegaDev2.DangerEmphasisBrush}" />
                        <TextBlock Text="pick your opponent"
                                   FontSize="10"
                                   Opacity="0.55"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    </StackPanel>
                    <ListView x:Name="HeroList"
                              Grid.Row="1"
                              SelectionChanged="HeroList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:PhantomHeroCard">
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                                    <Border Width="52" Height="40" CornerRadius="4"
                                            Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">
                                        <Image Source="{x:Bind Portrait, Mode=OneWay}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind Name}" FontSize="13" VerticalAlignment="Center" />
                                            <Border Background="{ThemeResource OmegaDev2.TeamUpBadgeBackgroundBrush}"
                                                    CornerRadius="3"
                                                    Padding="4,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind TeamUpBadgeVisibility}">
                                                <TextBlock Text="TEAM-UP" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource OmegaDev2.TeamUpBadgeForegroundBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind SubName}" FontSize="10" Opacity="0.55" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Hostiles in play -->
            <Border Grid.Column="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Hostiles In Play"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                        <Button Grid.Column="1" Content="Clear All" Click="ClearAll_Click" />
                    </Grid>

                    <ListView x:Name="EnemyList" Grid.Row="1" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:EnemyRow">
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="3" Margin="0,0,12,0">
                                        <TextBlock Text="{x:Bind Title}" FontSize="13" />
                                        <Grid Height="12">
                                            <Border CornerRadius="3" Background="{ThemeResource OmegaDev2.PageBackgroundBrush}" />
                                            <Border CornerRadius="3"
                                                    Width="{x:Bind BarWidth}"
                                                    HorizontalAlignment="Left"
                                                    Background="{x:Bind BarBrush}" />
                                        </Grid>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind HealthText}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Spawn panel -->
            <StackPanel Grid.Column="2" Spacing="12">
                <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Unleash"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SelectedHeroText"
                                       Grid.Column="0"
                                       Text="(random heroes)"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource OmegaDev2.DangerEmphasisBrush}" />
                            <Button Grid.Column="1" Content="✕" FontSize="10" Padding="6,2"
                                    Click="ClearHeroSelection_Click"
                                    ToolTipService.ToolTip="Back to random heroes" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox x:Name="CountBox" Header="Count" Value="1" Minimum="1" Maximum="20" SpinButtonPlacementMode="Compact" Width="110" />
                            <NumberBox x:Name="LevelBox" Header="Level (0 = match)" Value="0" Minimum="0" Maximum="60" SpinButtonPlacementMode="Compact" Width="180" />
                        </StackPanel>
                        <Button x:Name="SpawnBtn"
                                Content="Spawn Hostiles"
                                Click="Spawn_Click"
                                Background="#B03A3A"
                                Foreground="White"
                                HorizontalAlignment="Stretch" />
                        <TextBlock x:Name="SpawnStatusText"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Rogue Encounter"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                        <TextBlock Text="While roaming (never in hubs), 1–3 hostile heroes can spontaneously ambush you. 5-minute cooldown between events."
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Opacity="0.75" />
                        <ToggleSwitch x:Name="RogueSwitch"
                                      OnContent="On"
                                      OffContent="Off"
                                      Toggled="RogueSwitch_Toggled" />
                        <TextBlock x:Name="RogueStatusText"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Opacity="0.75"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        <Button Content="Trigger Now"
                                FontSize="12"
                                HorizontalAlignment="Stretch"
                                Click="RogueTriggerNow_Click" />
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Nemesis Roster"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                            <Button Grid.Column="1" Content="Refresh" FontSize="11" Click="NemesisRefresh_Click" />
                        </Grid>
                        <TextBlock Text="Phantoms that have killed you. Higher rank = tougher when they return in a Rogue Encounter. Kill them or banish to close the loop."
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Opacity="0.75" />
                        <ListView x:Name="NemesisList" SelectionMode="None" MaxHeight="220">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:NemesisRow">
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}" FontSize="13" />
                                            <TextBlock Text="{x:Bind Detail}" FontSize="10" Opacity="0.7" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind RankBadge}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OmegaDev2.DangerEmphasisBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />
                                        <Button Grid.Column="2"
                                                Content="Banish"
                                                FontSize="11"
                                                Tag="{x:Bind HeroRef}"
                                                Click="NemesisBanish_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock x:Name="NemesisStatusText"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="TIPS"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="180"
                                   Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                        <TextBlock Text="• Enemy phantoms leash to you — the fight stays on your screen."
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.8" />
                        <TextBlock Text="• They use ultimates. Bring friends (Phantom Heroes page)."
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.8" />
                        <TextBlock Text="• Corpses despawn a few seconds after the kill."
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.8" />
                        <TextBlock Text="• Watch the fight on the DPS Meter."
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.8" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
