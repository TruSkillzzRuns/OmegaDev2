<Page
    x:Class="OmegaDev2.Pages.MetaGameEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
    NavigationCacheMode="Required">

    <Grid Padding="24,20,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Region Events"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="960"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}"
                       Text="Browse and edit real MetaGame/MetaState prototypes (the machinery behind events like X-Defense) at runtime, or clone a field from one onto another. No new event can be created from scratch — this repurposes an existing, already-loaded one in place." />
        </StackPanel>

        <!-- Warning banner — do not water this down -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                BorderBrush="{ThemeResource OmegaDev2.DangerBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8">
            <TextBlock FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.DangerBrush}"
                       Text="Runtime prototype edits are global, live, and have no automatic revert — a write here affects every region/session referencing that prototype for the rest of the server session. Restart the server to fully reset. Confirm nothing else depends on a prototype before editing it." />
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="2"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ComboBox x:Name="BaseTypeCombo" Width="140" SelectedIndex="0">
                    <ComboBoxItem Content="MetaGame" />
                    <ComboBoxItem Content="MetaState" />
                </ComboBox>
                <TextBox x:Name="SearchBox" Width="240" PlaceholderText="search prototypes..." />
                <Button Content="Search" Click="Search_Click" />
                <TextBox x:Name="PlayerBox" Width="180" PlaceholderText="player (* = first online)" Text="*" />
                <TextBox x:Name="WarpRegionBox" Width="220" PlaceholderText="region protoRef (0x...) to warp into" />
                <Button Content="Warp Me There" Click="Warp_Click" />
            </StackPanel>
        </Border>

        <!-- Main: discover | field editor | clone -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Discover results -->
            <Border Grid.Column="0"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="PROTOTYPES" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160"
                               Margin="0,0,0,8"
                               Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <ListView x:Name="DiscoverList" Grid.Row="1" SelectionMode="Single" SelectionChanged="DiscoverList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ProtoDiscoverRow">
                                <StackPanel Margin="0,3" Spacing="1">
                                    <TextBlock Text="{x:Bind Name}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind Path}" FontSize="10" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Field editor -->
            <Border Grid.Column="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="14"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="SelectedProtoText" Text="(select a prototype)"
                               FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />

                    <ListView x:Name="FieldList" Grid.Row="1" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:FieldRow">
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="0">
                                        <TextBlock Text="{x:Bind FieldName}" FontSize="13" />
                                        <TextBlock Text="{x:Bind TypeLabel}" FontSize="10" Opacity="0.55" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind ValueText}" FontSize="12"
                                               TextWrapping="Wrap" VerticalAlignment="Center" Opacity="0.85" />
                                    <Border Grid.Column="2"
                                            Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
                                            CornerRadius="3" Padding="6,2"
                                            Visibility="{x:Bind ReadOnlyBadgeVisibility}">
                                        <TextBlock Text="read-only" FontSize="10" Opacity="0.6" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Generic write field -->
                    <Border Grid.Row="2"
                            Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,10,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="WRITE FIELD" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160"
                                       Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="WritePathBox" Width="200" PlaceholderText="path (e.g. Duration or Teams[0])" />
                                <ComboBox x:Name="WriteValueTypeCombo" Width="140" SelectedIndex="0">
                                    <ComboBoxItem Content="Float" />
                                    <ComboBoxItem Content="Integer" />
                                    <ComboBoxItem Content="Boolean" />
                                    <ComboBoxItem Content="String" />
                                    <ComboBoxItem Content="PrototypeId" />
                                    <ComboBoxItem Content="PrototypeGuid" />
                                    <ComboBoxItem Content="LocaleStringId" />
                                </ComboBox>
                                <TextBox x:Name="WriteValueBox" Width="220" PlaceholderText="new value" />
                                <Button Content="Write" Click="Write_Click" Style="{ThemeResource AccentButtonStyle}" />
                            </StackPanel>
                            <TextBlock x:Name="WriteStatusText" FontSize="11" TextWrapping="Wrap"
                                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Clone panel -->
            <Border Grid.Column="2"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="14">
                <StackPanel Spacing="8">
                    <TextBlock Text="CLONE FIELD" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160"
                               Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}"
                               Text="Copy a field's current value from one prototype onto another." />
                    <TextBox x:Name="CloneSourceBox" PlaceholderText="source protoRef (0x...)" />
                    <Button Content="Use Selected as Source" Click="UseSelectedAsSource_Click" HorizontalAlignment="Stretch" />
                    <TextBox x:Name="CloneTargetBox" PlaceholderText="target protoRef (0x...)" Margin="0,6,0,0" />
                    <Button Content="Use Selected as Target" Click="UseSelectedAsTarget_Click" HorizontalAlignment="Stretch" />
                    <TextBox x:Name="ClonePathBox" PlaceholderText="path (e.g. Duration)" Margin="0,6,0,0" />
                    <TextBox x:Name="CloneTargetPathBox" PlaceholderText="target path (blank = same as source)" />
                    <Button Content="Clone Field" Click="Clone_Click" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                    <TextBlock x:Name="CloneStatusText" FontSize="11" TextWrapping="Wrap"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
