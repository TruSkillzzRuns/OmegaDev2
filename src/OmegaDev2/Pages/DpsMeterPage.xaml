<Page
    x:Class="OmegaDev2.Pages.DpsMeterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="DPS Meter"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="Live damage tracking for your hero and every phantom individually — finally see who's carrying. Numbers are the actual health taken off targets, resists included."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ToggleButton x:Name="LiveToggle"
                              Content="Live"
                              IsChecked="True"
                              Checked="LiveToggle_Checked"
                              Unchecked="LiveToggle_Unchecked" />
                <TextBox x:Name="PlayerBox"
                         Width="220"
                         PlaceholderText="player (* = first online)"
                         Text="*"
                         VerticalAlignment="Center" />
                <Button Content="Reset Meter" Click="Reset_Click" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Combatant bars -->
        <Border Grid.Row="2"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="COMBATANT" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="1" Text="TOTAL" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" HorizontalAlignment="Right" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="2" Text="DPS (10s)" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" HorizontalAlignment="Right" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="3" Text="DPS (fight)" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" HorizontalAlignment="Right" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                </Grid>

                <ListView x:Name="DpsList" Grid.Row="1" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:DpsRow">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="130" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3" Margin="0,0,12,0">
                                    <TextBlock FontSize="13">
                                        <Run Text="{x:Bind Name}" />
                                        <Run Text="{x:Bind IdleText}" Foreground="Gray" />
                                    </TextBlock>
                                    <Border Height="12"
                                            CornerRadius="3"
                                            Width="{x:Bind BarWidth}"
                                            HorizontalAlignment="Left"
                                            Background="{x:Bind BarBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind TotalText}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Dps10Text}" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{x:Bind DpsAllText}" FontSize="13" Opacity="0.75" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

