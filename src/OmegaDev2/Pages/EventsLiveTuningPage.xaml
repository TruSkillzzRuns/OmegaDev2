<Page
    x:Class="OmegaDev2.Pages.EventsLiveTuningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
    NavigationCacheMode="Required">

    <Grid Padding="24,20,24,16" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Live Events"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}"
                       Text="MHO's own real live-tuning events (loot/XP multiplier holidays like OdinsBounty, WinterHoliday) — normally calendar-driven. Force one on right now for testing, or clear the override to restore the normal schedule." />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="RefreshBtn" Content="Refresh" Click="Refresh_Click" />
                <Button x:Name="ClearBtn" Content="Clear Override (restore normal schedule)" Click="Clear_Click" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Known events list -->
        <Border Grid.Row="2"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="KNOWN EVENTS — click Force On to activate one" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160"
                           Margin="0,0,0,8"
                           Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                <ListView x:Name="EventList" Grid.Row="1" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:LiveTuningEventRow">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontSize="13" VerticalAlignment="Center" />
                                <Border Grid.Column="1"
                                        Background="{ThemeResource OmegaDev2.AccentBrush}"
                                        CornerRadius="3"
                                        Padding="6,2"
                                        Margin="0,0,10,0"
                                        Visibility="{x:Bind ActiveBadgeVisibility}">
                                    <TextBlock Text="ACTIVE" FontSize="10" FontWeight="SemiBold" />
                                </Border>
                                <Button Grid.Column="2"
                                        Content="Force On"
                                        FontSize="11"
                                        Tag="{x:Bind Name}"
                                        Click="RowActivate_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Warning -->
        <Border Grid.Row="3"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="12,8">
            <TextBlock FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}"
                       Text="Force Activate is a full live-tuning reload for the whole server — every player's game instance re-reads settings. Not scoped to just you; don't spam it." />
        </Border>
    </Grid>
</Page>
