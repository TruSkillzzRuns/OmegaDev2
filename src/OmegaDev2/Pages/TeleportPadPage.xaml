<Page
    x:Class="OmegaDev2.Pages.TeleportPadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource OmegaDev2.BgBrush}"
    NavigationCacheMode="Enabled">

    <!-- Outer ScrollViewer so tight windows never truncate content. -->
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Padding="0"
                  Background="{ThemeResource OmegaDev2.BgBrush}">

        <!-- MinWidth ensures the two-column grid never collapses to 0. -->
        <Grid Padding="32,24,32,24" MinWidth="1100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
                <TextBlock Text="Teleport Pad"
                           FontSize="32"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                <TextBlock Text="Pick a region from the list and click Teleport. The list is pulled live from the server's safe-warp allowlist — no need to type prototype refs."
                           FontSize="13"
                           TextWrapping="Wrap"
                           MaxWidth="900"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>

            <!-- Server connection strip -->
            <Border Grid.Row="1"
                    Background="{ThemeResource OmegaDev2.PanelBrush}"
                    CornerRadius="6"
                    Padding="16,12"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" MinWidth="200" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Server URL"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    <TextBox x:Name="ServerUrlBox"
                             Grid.Column="1"
                             Text="http://localhost:8080"
                             VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            x:Name="RefreshButton"
                            Content="Load Regions"
                            Click="RefreshButton_Click"
                            Margin="12,0,0,0"
                            Padding="16,6"
                            MinWidth="150"
                            HorizontalAlignment="Stretch" />
                    <TextBlock Grid.Column="3"
                               x:Name="StatusText"
                               Text="Idle."
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                </Grid>
            </Border>

            <!-- Search + filter strip -->
            <Border Grid.Row="2"
                    Background="{ThemeResource OmegaDev2.PanelBrush}"
                    CornerRadius="6"
                    Padding="16,12"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Search"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             PlaceholderText="e.g. Avengers, Chapter 3, Danger Room"
                             TextChanged="SearchBox_TextChanged" />
                    <TextBlock Grid.Column="2"
                               Text="Category"
                               VerticalAlignment="Center"
                               Margin="24,0,0,0"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    <ComboBox x:Name="CategoryCombo"
                              Grid.Column="3"
                              SelectionChanged="CategoryCombo_SelectionChanged"
                              HorizontalAlignment="Stretch" />
                    <TextBlock Grid.Column="4"
                               x:Name="CountText"
                               Text=""
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                </Grid>
            </Border>

            <!-- Two-column body: region list + action panel -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="620" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="320" MinWidth="320" />
                </Grid.ColumnDefinitions>

                <!-- Region list -->
                <Border Grid.Column="0"
                        Background="{ThemeResource OmegaDev2.PanelBrush}"
                        CornerRadius="6"
                        Padding="0"
                        MinHeight="420">
                    <ListView x:Name="RegionList"
                              SelectionMode="Single"
                              SelectionChanged="RegionList_SelectionChanged"
                              Background="Transparent"
                              Padding="0,4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8,6" Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Path}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Action panel -->
                <Border Grid.Column="2"
                        Background="{ThemeResource OmegaDev2.PanelBrush}"
                        CornerRadius="6"
                        Padding="16"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Selected"
                                   FontSize="12"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        <TextBlock x:Name="SelectedName"
                                   Text="—"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                        <TextBlock x:Name="SelectedPath"
                                   Text=""
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />

                        <Button x:Name="TeleportButton"
                                Content="Teleport"
                                FontSize="16"
                                Padding="16,10"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource OmegaDev2.AccentBrush}"
                                Foreground="White"
                                IsEnabled="False"
                                Click="TeleportButton_Click" />

                        <TextBlock x:Name="LastActionText"
                                   Text=""
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
