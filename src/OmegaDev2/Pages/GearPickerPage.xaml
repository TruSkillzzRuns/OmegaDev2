<Page
    x:Class="OmegaDev2.Pages.GearPickerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Gear Picker"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="Browse every item in the loaded game data, build a basket, and deliver it to a player on the running server."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="LoadBtn" Content="Load Catalog" Click="LoadCatalog_Click" />
                <TextBox x:Name="SearchBox"
                         Width="260"
                         PlaceholderText="search name or path..."
                         TextChanged="SearchBox_TextChanged"
                         VerticalAlignment="Center" />
                <ComboBox x:Name="AvatarFilter"
                          Width="200"
                          SelectionChanged="AvatarFilter_SelectionChanged"
                          VerticalAlignment="Center" />
                <TextBlock x:Name="ShownCountText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                <StackPanel x:Name="IconProgressPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed"
                            VerticalAlignment="Center">
                    <ProgressBar x:Name="IconProgressBar"
                                 Width="220"
                                 MinHeight="10"
                                 Minimum="0"
                                 VerticalAlignment="Center" />
                    <TextBlock x:Name="IconProgressText"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main: categories | items | basket -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="255" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Categories -->
            <Border Grid.Column="0"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="6"
                    Margin="0,0,12,0">
                <ListView x:Name="CategoryList"
                          SelectionChanged="CategoryList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:GearCategory">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind Name}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind CountText}"
                                           Opacity="0.55"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Item grid -->
            <Border Grid.Column="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="8"
                    Margin="0,0,12,0">
                <GridView x:Name="ItemsGrid"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="ItemsGrid_ItemClick">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:GearItemCard">
                            <Border Width="230" Height="190"
                                    CornerRadius="6"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="{x:Bind CategoryBrush}"
                                    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
                                    Padding="12,10"
                                    ToolTipService.ToolTip="{x:Bind Path}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Image Grid.Row="0"
                                           Height="72" Width="72"
                                           HorizontalAlignment="Left"
                                           Source="{x:Bind Icon, Mode=OneWay}"
                                           Stretch="Uniform" />
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind Name}"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="3"
                                               Margin="0,6,0,0"
                                               Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                                    <TextBlock Grid.Row="2"
                                               Text="{x:Bind SubLabel}"
                                               FontSize="11"
                                               Opacity="0.6"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Border>

            <!-- Basket -->
            <Border Grid.Column="2"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Basket"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />

                    <!-- Delivery defaults -->
                    <StackPanel Grid.Row="1" Spacing="6" Margin="0,0,0,10">
                        <TextBox x:Name="PlayerBox"
                                 Header="Player (name, 0xDbId, or * for first online)"
                                 Text="*" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox x:Name="DefaultCountBox" Header="Count" Value="1" Minimum="1" Maximum="100" SpinButtonPlacementMode="Compact" Width="110" />
                            <NumberBox x:Name="DefaultLevelBox" Header="Level (0 = auto)" Value="0" Minimum="0" Maximum="100" SpinButtonPlacementMode="Compact" Width="180" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Basket rows -->
                    <ListView x:Name="BasketList" Grid.Row="2" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:BasketEntry">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <NumberBox Value="{x:Bind Count, Mode=TwoWay}" Minimum="1" Maximum="100" Width="90" SpinButtonPlacementMode="Compact" />
                                            <ComboBox ItemsSource="{x:Bind RarityLabels}"
                                                      SelectedIndex="{x:Bind RarityIndex, Mode=TwoWay}"
                                                      FontSize="11"
                                                      Width="160" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            FontSize="10"
                                            Padding="6,2"
                                            VerticalAlignment="Top"
                                            Tag="{x:Bind ProtoRef}"
                                            Click="RemoveFromBasket_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Actions -->
                    <StackPanel Grid.Row="3" Spacing="6" Margin="0,10,0,0">
                        <TextBlock x:Name="BasketStatusText"
                                   Text="empty"
                                   FontSize="11"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="SendBtn" Content="Send to Player" Click="Send_Click" Style="{ThemeResource AccentButtonStyle}" />
                            <Button Content="Clear" Click="ClearBasket_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
