<Page
    x:Class="OmegaDev2.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <ScrollViewer Padding="24,20,24,20" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="820" HorizontalAlignment="Left">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Settings"
                           FontSize="32"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                <TextBlock Text="App preferences, version info, and updates."
                           FontSize="13"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>

            <!-- Updates -->
            <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="UPDATES"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="180"
                                   Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                        <TextBlock Text="Check GitHub Releases for a newer OmegaDev2 build."
                                   FontSize="12"
                                   Opacity="0.7" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center" Margin="0,0,20,0">
                            <TextBlock FontSize="11" Opacity="0.55" Text="INSTALLED" CharacterSpacing="120" />
                            <TextBlock x:Name="CurrentVersionText"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="v?" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock FontSize="11" Opacity="0.55" Text="LATEST" CharacterSpacing="120" />
                            <TextBlock x:Name="LatestVersionText"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="—" />
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="UpdateStatusText"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}"
                               Text="Press Check for Updates to look for a new release." />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="CheckBtn"
                                Content="Check for Updates"
                                Click="Check_Click" />
                        <Button x:Name="InstallBtn"
                                Content="Download and Install"
                                Click="Install_Click"
                                IsEnabled="False"
                                Background="{ThemeResource OmegaDev2.AccentBrush}"
                                Foreground="White" />
                        <Button x:Name="ReleaseNotesBtn"
                                Content="View Release Notes"
                                Click="Notes_Click"
                                IsEnabled="False" />
                    </StackPanel>

                    <ProgressBar x:Name="DownloadProgress"
                                 Minimum="0" Maximum="100" Value="0"
                                 Visibility="Collapsed"
                                 Height="6" />

                    <Border x:Name="ReleaseNotesPanel"
                            Visibility="Collapsed"
                            Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
                            CornerRadius="4"
                            Padding="12"
                            MaxHeight="240">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ReleaseNotesText"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"
                                       Opacity="0.85" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="16">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="APPEARANCE"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="180"
                                   Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                        <TextBlock Text="Switch between light and dark mode without touching your Windows settings. Applies instantly."
                                   FontSize="12"
                                   Opacity="0.65"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <RadioButton x:Name="ThemeSystemRadio" Content="Use Windows setting" GroupName="ThemeMode" Checked="ThemeRadio_Checked" Tag="System" />
                        <RadioButton x:Name="ThemeLightRadio"  Content="Light" GroupName="ThemeMode" Checked="ThemeRadio_Checked" Tag="Light" />
                        <RadioButton x:Name="ThemeDarkRadio"   Content="Dark"  GroupName="ThemeMode" Checked="ThemeRadio_Checked" Tag="Dark" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="ABOUT"
                               FontSize="11"
                               FontWeight="SemiBold"
                               CharacterSpacing="180"
                               Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock FontSize="13" Text="OmegaDev2 — companion tools for the 1.52 MHServerEmu phantom-heroes fork." TextWrapping="Wrap" Opacity="0.85" />
                    <TextBlock FontSize="12" Opacity="0.6" Text="Repository: github.com/TruSkillzzRuns/OmegaDev2" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
