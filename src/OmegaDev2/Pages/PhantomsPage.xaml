<Page
    x:Class="OmegaDev2.Pages.PhantomsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Phantom Heroes"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="Spawn, dress, gear and manage the AI hero bots that fight alongside a player. Click roster heroes into the Lineup for full per-slot control, or use Quick Spawn for a fast batch of randoms. Saved squads are shared by both."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="960"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar (shared) -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="LoadBtn" Content="Load Roster" Click="LoadRoster_Click" />
                <TextBox x:Name="SearchBox"
                         Width="220"
                         PlaceholderText="search hero..."
                         TextChanged="SearchBox_TextChanged"
                         VerticalAlignment="Center" />
                <TextBox x:Name="PlayerBox"
                         Width="220"
                         PlaceholderText="player (* = first online)"
                         Text="*"
                         VerticalAlignment="Center" />
                <CheckBox x:Name="BypassCapCheck"
                          Content="Bypass party/raid size limit"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Ignores the game's real party (5) / raid (10) size cap for every spawn action below" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Main: roster | (quick spawn+active / lineup builder) | saved squads -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Hero roster (shared — click adds to Lineup) -->
            <Border Grid.Column="0"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="6"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Spacing="2" Margin="8,6,8,6">
                        <TextBlock Text="HERO ROSTER"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="180"
                                   Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                        <TextBlock Text="click to add to lineup"
                                   FontSize="10"
                                   Opacity="0.55"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    </StackPanel>
                    <ListView x:Name="HeroList"
                              Grid.Row="1"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="HeroList_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:PhantomHeroCard">
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                                    <Border Width="52" Height="40" CornerRadius="4"
                                            Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">
                                        <Image Source="{x:Bind Portrait, Mode=OneWay}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind Name}" FontSize="13" VerticalAlignment="Center" />
                                            <Border Background="{ThemeResource OmegaDev2.TeamUpBadgeBackgroundBrush}"
                                                    CornerRadius="3"
                                                    Padding="4,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind TeamUpBadgeVisibility}">
                                                <TextBlock Text="TEAM-UP" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource OmegaDev2.TeamUpBadgeForegroundBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind SubName}" FontSize="10" Opacity="0.55" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Middle: Pivot between quick-spawn/active and lineup builder -->
            <Pivot x:Name="MainPivot" Grid.Column="1" Margin="0,0,12,0">
                <PivotItem Header="Quick Spawn &amp; Active">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Quick random spawn -->
                        <Border Grid.Row="0"
                                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Quick Random Spawn"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <NumberBox x:Name="CountBox" Header="Count" Value="5" Minimum="1" Maximum="50" SpinButtonPlacementMode="Compact" Width="110" />
                                    <NumberBox x:Name="LevelBox" Header="Level (0 = match)" Value="0" Minimum="0" Maximum="60" SpinButtonPlacementMode="Compact" Width="180" />
                                    <CheckBox x:Name="LockLevelCheck" Content="Lock level" IsChecked="True" VerticalAlignment="Bottom" />
                                </StackPanel>
                                <Button x:Name="SpawnBtn"
                                        Content="Spawn Random"
                                        Click="Spawn_Click"
                                        Style="{ThemeResource AccentButtonStyle}" />
                                <TextBlock x:Name="SpawnStatusText"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Active phantoms -->
                        <Border Grid.Row="1"
                                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                                CornerRadius="6"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Active Phantoms"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                                    <Button Grid.Column="1" Content="Refresh" Click="RefreshActive_Click" />
                                </Grid>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                                    <Button Content="Clear All" Click="ClearAll_Click" />
                                    <Button Content="Reroll All Gear" Click="RerollAllGear_Click" />
                                    <Button Content="Randomize All Costumes" Click="RandomizeAllCostumes_Click" />
                                </StackPanel>

                                <ListView x:Name="ActiveList" Grid.Row="2" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:ActivePhantomRow">
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Title}" FontSize="13" />
                                                    <TextBlock Text="{x:Bind Detail}" FontSize="10" Opacity="0.55" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="Costume 🎲"
                                                        FontSize="11"
                                                        Margin="0,0,6,0"
                                                        Tag="{x:Bind Username}"
                                                        Click="RowRandomCostume_Click" />
                                                <Button Grid.Column="2"
                                                        Content="Gear ↻"
                                                        FontSize="11"
                                                        Tag="{x:Bind Username}"
                                                        Click="RowRerollGear_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Lineup Builder">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="LineupTitle"
                                           Text="Lineup (0)"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                                <TextBlock Text="Game's real caps still apply on spawn: max 5 in story/campaign regions, 10 in raids (unless bypassed above)."
                                           FontSize="11"
                                           Opacity="0.7"
                                           Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Export Code" Click="ExportCode_Click" Margin="0,0,8,0"
                                    ToolTipService.ToolTip="Copy the current lineup to a shareable code" />
                            <Button Grid.Column="2" Content="Import Code" Click="ImportCode_Click" Margin="0,0,8,0"
                                    ToolTipService.ToolTip="Paste a squad code to load it into the lineup" />
                            <Button Grid.Column="3" Content="Clear Lineup" Click="ClearLineup_Click" VerticalAlignment="Center" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                                CornerRadius="6"
                                Padding="8">
                            <ListView x:Name="LineupList" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:LineupSlot">
                                        <Border Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="64" Height="48" CornerRadius="4"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center"
                                                        Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}">
                                                    <Image Source="{x:Bind Portrait, Mode=OneWay}" Stretch="UniformToFill" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind HeroName}" FontSize="14" FontWeight="SemiBold" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <NumberBox Header="Level (0 = match)"
                                                                   Value="{x:Bind Level, Mode=TwoWay}"
                                                                   Minimum="0" Maximum="60"
                                                                   SpinButtonPlacementMode="Compact"
                                                                   Width="140" />
                                                        <CheckBox Content="Lock"
                                                                  IsChecked="{x:Bind LockLevel, Mode=TwoWay}"
                                                                  VerticalAlignment="Bottom" />
                                                        <ComboBox Header="Costume"
                                                                  ItemsSource="{x:Bind CostumeLabels, Mode=OneWay}"
                                                                  SelectedIndex="{x:Bind CostumeIndex, Mode=TwoWay}"
                                                                  Width="220"
                                                                  Visibility="{x:Bind CostumeVisibility}" />
                                                        <Border Background="{ThemeResource OmegaDev2.TeamUpBadgeBackgroundBrush}"
                                                                CornerRadius="3"
                                                                Padding="6,2"
                                                                VerticalAlignment="Bottom"
                                                                Visibility="{x:Bind TeamUpBadgeVisibility}">
                                                            <TextBlock Text="TEAM-UP" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource OmegaDev2.TeamUpBadgeForegroundBrush}" />
                                                        </Border>
                                                        <CheckBox Content="Invincible"
                                                                  IsChecked="{x:Bind Invincible, Mode=TwoWay}"
                                                                  VerticalAlignment="Bottom"
                                                                  ToolTipService.ToolTip="Cannot be downed or killed" />
                                                        <Button Content="Rotation…"
                                                                VerticalAlignment="Bottom"
                                                                Tag="{x:Bind SlotId}"
                                                                Click="OpenRotation_Click"
                                                                ToolTipService.ToolTip="Pick a preferred power for this hero (applies to every phantom of this hero, not just this squad)" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Content="✕"
                                                        FontSize="10"
                                                        Padding="8,4"
                                                        VerticalAlignment="Top"
                                                        Tag="{x:Bind SlotId}"
                                                        Click="RemoveSlot_Click" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!-- Save / spawn -->
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SquadNameBox"
                                     Grid.Column="0"
                                     PlaceholderText="squad name (letters, digits, _ -)"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1"
                                    Content="Spawn Now"
                                    Click="SpawnNow_Click"
                                    Margin="0,0,8,0"
                                    ToolTipService.ToolTip="Spawn the lineup immediately — auto-names it if you left the name blank" />
                            <Button Grid.Column="2"
                                    Content="Save Squad"
                                    Click="SaveSquad_Click"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Margin="0,0,8,0" />
                            <Button Grid.Column="3"
                                    Content="Save + Spawn"
                                    Click="SaveAndSpawn_Click" />
                        </Grid>
                    </Grid>
                </PivotItem>
            </Pivot>

            <!-- Saved squads (shared) -->
            <Border Grid.Column="2"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Saved Squads"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                        <Button Grid.Column="1" Content="Refresh" FontSize="11" Click="RefreshSquads_Click" />
                    </Grid>
                    <ListView x:Name="SquadList" Grid.Row="1" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:SquadRow">
                                <Grid Margin="0,2" ToolTipService.ToolTip="{x:Bind HeroesTip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontSize="13" />
                                        <TextBlock Text="{x:Bind Detail}" FontSize="10" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Edit"
                                            FontSize="11"
                                            Margin="0,0,6,0"
                                            Tag="{x:Bind Name}"
                                            Click="EditSquad_Click" />
                                    <Button Grid.Column="2"
                                            Content="Spawn"
                                            FontSize="11"
                                            Margin="0,0,6,0"
                                            Tag="{x:Bind Name}"
                                            Click="SpawnSquad_Click" />
                                    <Button Grid.Column="3"
                                            Content="✕"
                                            FontSize="10"
                                            Padding="6,2"
                                            Tag="{x:Bind Name}"
                                            Click="DeleteSquad_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="SquadStatusText"
                               Grid.Row="2"
                               FontSize="11"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
