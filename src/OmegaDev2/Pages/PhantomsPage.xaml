<Page
    x:Class="OmegaDev2.Pages.PhantomsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Phantom Heroes"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="Spawn, dress, gear and manage the AI hero bots that fight alongside a player — the full !phantom command set over WebAPI."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="LoadBtn" Content="Load Roster" Click="LoadRoster_Click" />
                <TextBox x:Name="SearchBox"
                         Width="220"
                         PlaceholderText="search hero..."
                         TextChanged="SearchBox_TextChanged"
                         VerticalAlignment="Center" />
                <TextBox x:Name="PlayerBox"
                         Width="230"
                         PlaceholderText="player (* = first online)"
                         Text="*"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Main: roster | active | controls -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Hero roster -->
            <Border Grid.Column="0"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="6"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="HERO ROSTER"
                               FontSize="11"
                               FontWeight="SemiBold"
                               CharacterSpacing="180"
                               Margin="8,6,8,6"
                               Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <ListView x:Name="HeroList"
                              Grid.Row="1"
                              SelectionChanged="HeroList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:PhantomHeroCard">
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                                    <Border Width="52" Height="40" CornerRadius="4"
                                            Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">
                                        <Image Source="{x:Bind Portrait, Mode=OneWay}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind Name}" FontSize="13" VerticalAlignment="Center" />
                                            <Border Background="{ThemeResource OmegaDev2.TeamUpBadgeBackgroundBrush}"
                                                    CornerRadius="3"
                                                    Padding="4,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind TeamUpBadgeVisibility}">
                                                <TextBlock Text="TEAM-UP" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource OmegaDev2.TeamUpBadgeForegroundBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind SubName}" FontSize="10" Opacity="0.55" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Active phantoms -->
            <Border Grid.Column="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Active Phantoms"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                        <Button Grid.Column="1" Content="Refresh" Click="RefreshActive_Click" />
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                        <Button Content="Clear All" Click="ClearAll_Click" />
                        <Button Content="Reroll All Gear" Click="RerollAllGear_Click" />
                        <Button Content="Randomize All Costumes" Click="RandomizeAllCostumes_Click" />
                    </StackPanel>

                    <ListView x:Name="ActiveList" Grid.Row="2" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ActivePhantomRow">
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Title}" FontSize="13" />
                                        <TextBlock Text="{x:Bind Detail}" FontSize="10" Opacity="0.55" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Costume 🎲"
                                            FontSize="11"
                                            Margin="0,0,6,0"
                                            Tag="{x:Bind Username}"
                                            Click="RowRandomCostume_Click" />
                                    <Button Grid.Column="2"
                                            Content="Gear ↻"
                                            FontSize="11"
                                            Tag="{x:Bind Username}"
                                            Click="RowRerollGear_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Controls: spawn + squads -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">

                    <!-- Spawn -->
                    <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Spawn"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SelectedHeroText"
                                           Grid.Column="0"
                                           Text="(random heroes)"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                                <Button Grid.Column="1" Content="✕" FontSize="10" Padding="6,2"
                                        Click="ClearHeroSelection_Click"
                                        ToolTipService.ToolTip="Back to random heroes" />
                            </Grid>
                            <ComboBox x:Name="CostumeCombo"
                                      Header="Costume"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="False" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <NumberBox x:Name="CountBox" Header="Count" Value="5" Minimum="1" Maximum="50" SpinButtonPlacementMode="Compact" Width="110" />
                                <NumberBox x:Name="LevelBox" Header="Level (0 = match)" Value="0" Minimum="0" Maximum="60" SpinButtonPlacementMode="Compact" Width="180" />
                            </StackPanel>
                            <CheckBox x:Name="LockLevelCheck" Content="Lock level (no auto-level with player)" IsChecked="True" />
                            <Button x:Name="SpawnBtn"
                                    Content="Spawn"
                                    Click="Spawn_Click"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Stretch" />
                            <TextBlock x:Name="SpawnStatusText"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Squads -->
                    <Border Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Saved Squads"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                                <Button Grid.Column="1" Content="Refresh" FontSize="11" Click="RefreshSquads_Click" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SquadNameBox"
                                         Grid.Column="0"
                                         PlaceholderText="squad name"
                                         ToolTipService.ToolTip="1-32 characters: letters, digits, _ or -"
                                         Margin="0,0,6,0" />
                                <Button Grid.Column="1" Content="Save Current" Click="SaveSquad_Click" />
                            </Grid>
                            <ListView x:Name="SquadList" SelectionMode="None" MaxHeight="320">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:SquadRow">
                                        <Grid Margin="0,2" ToolTipService.ToolTip="{x:Bind HeroesTip}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Name}" FontSize="13" />
                                                <TextBlock Text="{x:Bind Detail}" FontSize="10" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Spawn"
                                                    FontSize="11"
                                                    Margin="0,0,6,0"
                                                    Tag="{x:Bind Name}"
                                                    Click="SpawnSquad_Click" />
                                            <Button Grid.Column="2"
                                                    Content="✕"
                                                    FontSize="10"
                                                    Padding="6,2"
                                                    Tag="{x:Bind Name}"
                                                    Click="DeleteSquad_Click" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock x:Name="SquadStatusText"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
