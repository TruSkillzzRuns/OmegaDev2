<Page
    x:Class="OmegaDev2.Pages.CurrencyEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Currency Editor"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="View and set individual currency balances — unlike the givecurrency command (which grants ALL currencies at once), this targets one at a time to whatever amount you type."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="RefreshBtn" Content="Refresh" Click="Refresh_Click" />
                <TextBox x:Name="PlayerBox"
                         Width="220"
                         PlaceholderText="player (* = first online)"
                         Text="*"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Currency list -->
        <Border Grid.Row="2"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CURRENCY" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="1" Text="BALANCE" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock Grid.Column="2" Text="SET TO" FontSize="11" FontWeight="SemiBold" CharacterSpacing="160" Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                </Grid>
                <ListView x:Name="CurrencyList" Grid.Row="1" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:CurrencyRow">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind AmountText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{x:Bind NewAmountText, Mode=TwoWay}" Margin="0,0,8,0" />
                                <Button Grid.Column="3" Content="Set" Tag="{x:Bind ProtoRef}" Click="SetOne_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
