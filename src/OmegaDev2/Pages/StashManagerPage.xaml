<Page
    x:Class="OmegaDev2.Pages.StashManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OmegaDev2.Pages"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="Stash Manager"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
            <TextBlock Text="Browse a player's inventory and stash tabs with real names, icons and rarity colors — and clean out the junk without logging in."
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="900"
                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="LoadBtn" Content="Load Inventory" Click="LoadInventory_Click" />
                <TextBox x:Name="PlayerBox"
                         Width="220"
                         PlaceholderText="player (* = first online)"
                         Text="*"
                         VerticalAlignment="Center" />
                <TextBox x:Name="SearchBox"
                         Width="240"
                         PlaceholderText="filter items..."
                         TextChanged="SearchBox_TextChanged"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Main: containers | items -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Containers -->
            <Border Grid.Column="0"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="6"
                    Margin="0,0,12,0">
                <ListView x:Name="ContainerList"
                          SelectionChanged="ContainerList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:StashContainerRow">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="1">
                                    <TextBlock Text="{x:Bind Name}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind SubLabel}" FontSize="10" Opacity="0.55" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind CountText}"
                                           FontSize="11"
                                           Opacity="0.55"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Items -->
            <Border Grid.Column="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="8">
                <GridView x:Name="ItemsGrid" SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:StashItemCard">
                            <Border Width="210" Height="120"
                                    CornerRadius="6"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="{x:Bind RarityBrush}"
                                    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}"
                                    Padding="10,8"
                                    ToolTipService.ToolTip="{x:Bind Tooltip}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0"
                                               Width="48" Height="48"
                                               VerticalAlignment="Top"
                                               Source="{x:Bind Icon, Mode=OneWay}"
                                               Stretch="Uniform"
                                               Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="3" />
                                        <Button Grid.Column="2"
                                                Content="✕"
                                                FontSize="10"
                                                Padding="6,2"
                                                VerticalAlignment="Top"
                                                Tag="{x:Bind EntityId}"
                                                Click="DeleteItem_Click"
                                                ToolTipService.ToolTip="Delete this item" />
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind SubLabel}"
                                               FontSize="10"
                                               Opacity="0.6"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Border>
        </Grid>
    </Grid>
</Page>
