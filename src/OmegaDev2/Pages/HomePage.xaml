<Page
    x:Class="OmegaDev2.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ToolCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource OmegaDev2.PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource OmegaDev2.PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="MinHeight" Value="130" />
        </Style>
    </Page.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">
        <Grid Padding="40,32,40,32" MinWidth="1000">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="14" Margin="0,0,0,32">
                <Border CornerRadius="10"
                        HorizontalAlignment="Center"
                        BorderBrush="{ThemeResource OmegaDev2.PanelBorderBrush}"
                        BorderThickness="1">
                    <Image Source="ms-appx:///Assets/OmegaDev2Logo.jpg"
                           Stretch="Uniform"
                           Height="300" />
                </Border>
                <TextBlock Text="Server-side dev tools for the 1.52 MHServerEmu fork. Sibling to OmegaDev — no sip touching, everything over WebAPI."
                           FontSize="15"
                           MaxWidth="900"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    BorderBrush="{ThemeResource OmegaDev2.PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20,16"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" MinWidth="200" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Server URL"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    <TextBox x:Name="ServerUrlBox"
                             Grid.Column="1"
                             Text="http://localhost:8080"
                             VerticalAlignment="Center"
                             TextChanged="ServerUrlBox_TextChanged" />
                    <Button Grid.Column="2"
                            x:Name="ApplyButton"
                            Content="Apply Everywhere"
                            Click="ApplyButton_Click"
                            Margin="12,0,0,0"
                            Padding="16,6"
                            MinWidth="150"
                            HorizontalAlignment="Stretch" />
                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="20,0,0,0"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot"
                                 Width="10" Height="10"
                                 Fill="{ThemeResource OmegaDev2.DangerBrush}" />
                        <TextBlock x:Name="StatusText"
                                   Text="Checking…"
                                   FontSize="13"
                                   Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Spacing="12" Margin="0,0,0,24">
                <TextBlock Text="REGIONS"
                           FontSize="12"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"
                           Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="340" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource ToolCardStyle}" Tag="teleportpad" Tapped="ToolCard_Tapped">
                        <StackPanel Spacing="8">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE909;" FontSize="24" Foreground="{ThemeResource OmegaDev2.AccentBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="Teleport Pad" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Pick a safe-warp region and jump."
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3" Spacing="12" Margin="0,0,0,24">
                <TextBlock Text="PHANTOMS"
                           FontSize="12"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"
                           Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="340" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource ToolCardStyle}" Tag="phantoms" Tapped="ToolCard_Tapped">
                        <StackPanel Spacing="8">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE716;" FontSize="24" Foreground="{ThemeResource OmegaDev2.AccentBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="Phantom Heroes" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Spawn, dress and manage AI hero bots — squads, costumes, gear."
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="4" Spacing="12" Margin="0,0,0,24">
                <TextBlock Text="LOOT"
                           FontSize="12"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"
                           Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="340" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource ToolCardStyle}" Tag="gearpicker" Tapped="ToolCard_Tapped">
                        <StackPanel Spacing="8">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7B8;" FontSize="24" Foreground="{ThemeResource OmegaDev2.AccentBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="Gear Picker" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Browse the item catalog and send gear to any player."
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="5" Spacing="12">
                <TextBlock Text="SERVER"
                           FontSize="12"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"
                           Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="340" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource ToolCardStyle}" Tag="diagnostics" Tapped="ToolCard_Tapped">
                        <StackPanel Spacing="8">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9F9;" FontSize="24" Foreground="{ThemeResource OmegaDev2.AccentBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="Diagnostics" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Debug console — errors, warnings, uptime, at-a-glance health."
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
