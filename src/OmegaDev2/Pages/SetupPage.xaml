<Page
    x:Class="OmegaDev2.Pages.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource OmegaDev2.PageBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="24,20,24,16" MaxWidth="980" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
                <TextBlock Text="Asset Setup"
                           FontSize="32"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                <TextBlock Text="Point OmegaDev2 at your server folder and your game client install, then hit Apply — item icons, hero portraits and real item names get configured automatically. Textures and strings are read from your own client files; nothing is redistributed."
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>

            <!-- Folder pickers -->
            <Border Grid.Row="1"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="16,14"
                    Margin="0,0,0,12">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ServerDirBox"
                                 Grid.Column="0"
                                 Header="Server folder (contains MHServerEmu.exe and Config.ini)"
                                 PlaceholderText="e.g. ...\MHServerEmu\bin"
                                 TextChanged="Paths_Changed"
                                 Margin="0,0,10,0" />
                        <Button Grid.Column="1"
                                Content="Browse..."
                                VerticalAlignment="Bottom"
                                Click="BrowseServer_Click" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ClientDirBox"
                                 Grid.Column="0"
                                 Header="Game client install folder"
                                 PlaceholderText="the game's install directory"
                                 TextChanged="Paths_Changed"
                                 Margin="0,0,10,0" />
                        <Button Grid.Column="1"
                                Content="Browse..."
                                VerticalAlignment="Bottom"
                                Click="BrowseClient_Click" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RepoDirBox"
                                 Grid.Column="0"
                                 Header="Server repo folder (only needed to build the extraction tools)"
                                 PlaceholderText="the cloned server source — repo root or its tools folder"
                                 TextChanged="Paths_Changed"
                                 Margin="0,0,10,0" />
                        <Button Grid.Column="1"
                                Content="Browse..."
                                VerticalAlignment="Bottom"
                                Margin="0,0,10,0"
                                Click="BrowseRepo_Click" />
                        <Button x:Name="BuildToolsBtn"
                                Grid.Column="2"
                                Content="Build Tools"
                                VerticalAlignment="Bottom"
                                IsEnabled="False"
                                Click="BuildTools_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Checklist -->
            <Border Grid.Row="2"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="16,14"
                    Margin="0,0,0,12">
                <StackPanel Spacing="6">
                    <TextBlock Text="CHECKLIST"
                               FontSize="11"
                               FontWeight="SemiBold"
                               CharacterSpacing="180"
                               Margin="0,0,0,4"
                               Foreground="{ThemeResource OmegaDev2.AccentBrush}" />
                    <TextBlock x:Name="CheckServer"   FontSize="13" TextWrapping="Wrap" Text="—  server folder" />
                    <TextBlock x:Name="CheckCooked"   FontSize="13" TextWrapping="Wrap" Text="—  client CookedPCConsole folder" />
                    <TextBlock x:Name="CheckManifest" FontSize="13" TextWrapping="Wrap" Text="—  texture cache manifest" />
                    <TextBlock x:Name="CheckTools"    FontSize="13" TextWrapping="Wrap" Text="—  extraction tools (Tools\UpkExtract, Tools\TfcExtract)" />
                    <TextBlock x:Name="CheckLocale"   FontSize="13" TextWrapping="Wrap" Text="—  locale files (item names)" />
                    <TextBlock x:Name="CheckConfig"   FontSize="13" TextWrapping="Wrap" Text="—  Config.ini configured" />
                    <TextBlock x:Name="CheckIndex"    FontSize="13" TextWrapping="Wrap" Text="—  texture index (Cache\texIndex.json)" />
                </StackPanel>
            </Border>

            <!-- Apply -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
                <Button x:Name="ApplyBtn"
                        Content="Apply Setup"
                        Style="{ThemeResource AccentButtonStyle}"
                        MinWidth="140"
                        IsEnabled="False"
                        Click="Apply_Click" />
                <Button Content="Re-check" Click="Recheck_Click" />
                <TextBlock x:Name="ApplyStatusText"
                           VerticalAlignment="Center"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource OmegaDev2.TextSecondaryBrush}" />
            </StackPanel>

            <!-- Progress output -->
            <Border Grid.Row="4"
                    x:Name="OutputPanel"
                    Background="{ThemeResource OmegaDev2.PanelBackgroundBrush}"
                    CornerRadius="6"
                    Padding="10"
                    Visibility="Collapsed">
                <ScrollViewer x:Name="OutputScroll" MaxHeight="260" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="OutputText"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource OmegaDev2.TextPrimaryBrush}" />
                </ScrollViewer>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
